# =============================================================================
# Concierge — Environment Variables
# =============================================================================
# Copy this file to .env.local for development:
#   cp .env.example .env.local
#
# NEVER commit .env.local or any file containing real secrets.
# All secrets in production are managed via AWS KMS / Secrets Manager.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL 16+)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/concierge_dev"
DATABASE_URL_TEST="postgresql://postgres:postgres@localhost:5432/concierge_test"
# Read replica for reports/analytics (same as primary in development)
DATABASE_READ_URL="postgresql://postgres:postgres@localhost:5432/concierge_dev"

# -----------------------------------------------------------------------------
# Redis (caching, rate limiting, session deny list, BullMQ)
# -----------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"
BULL_REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# Authentication — JWT (RS256)
# Generate dev keys:
#   openssl genrsa -out keys/private.pem 2048
#   openssl rsa -in keys/private.pem -pubout -out keys/public.pem
#
# Or set inline (replace newlines with \n):
# -----------------------------------------------------------------------------
JWT_PRIVATE_KEY_PATH="./keys/private.pem"
JWT_PUBLIC_KEY_PATH="./keys/public.pem"
# Alternatively, set keys inline (overrides *_PATH if both set):
# JWT_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
JWT_ACCESS_TOKEN_EXPIRY="15m"
JWT_REFRESH_TOKEN_EXPIRY="7d"

# -----------------------------------------------------------------------------
# Authentication — 2FA (TOTP)
# -----------------------------------------------------------------------------
TOTP_ISSUER="Concierge"

# -----------------------------------------------------------------------------
# Email (Resend — primary) / AWS SES (fallback)
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_test_xxxx"
RESEND_FROM_EMAIL="noreply@concierge.app"
AWS_SES_REGION="ca-central-1"
AWS_SES_FROM_EMAIL="noreply@concierge.app"

# -----------------------------------------------------------------------------
# SMS & Voice (Twilio)
# -----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""

# -----------------------------------------------------------------------------
# Object Storage (AWS S3) — ca-central-1 for PIPEDA compliance
# -----------------------------------------------------------------------------
AWS_S3_BUCKET="concierge-dev"
AWS_S3_REGION="ca-central-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# -----------------------------------------------------------------------------
# Error Tracking (Sentry)
# -----------------------------------------------------------------------------
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# -----------------------------------------------------------------------------
# CORS — Strict origin allowlist (comma-separated)
# -----------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS="http://localhost:3000"

# -----------------------------------------------------------------------------
# AI Providers (optional for dev)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""

# -----------------------------------------------------------------------------
# Encryption (AWS KMS) — Production only
# Per-property keys derived from these master keys
# -----------------------------------------------------------------------------
# KMS_PRIMARY_KEY_ID=""
# KMS_BACKUP_KEY_ID=""

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
FEATURE_FLAG_PROVIDER="local"

# -----------------------------------------------------------------------------
# Stripe (Billing & Subscription — PRD 24)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# -----------------------------------------------------------------------------
# Firebase Cloud Messaging (Push Notifications)
# -----------------------------------------------------------------------------
# Project ID from Firebase Console
FIREBASE_PROJECT_ID=""
# Service account key JSON (single line, from Firebase Console > Project Settings > Service Accounts)
FIREBASE_SERVICE_ACCOUNT_KEY=""
