// ---------------------------------------------------------------------------
// Inspections — CLAUDE.md Phase 2: Mobile-first with checklists, GPS verification
// ---------------------------------------------------------------------------

model InspectionTemplate {
  id          String   @id @default(uuid()) @db.Uuid
  propertyId  String   @map("property_id") @db.Uuid
  name        String   @db.VarChar(200)
  category    String   @db.VarChar(50) // fire_safety, hvac, elevator, pool
  description String?  @db.VarChar(2000)
  items       Json     @db.JsonB // Array of { name, required, type }
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  inspections Inspection[]

  @@index([propertyId])
  @@index([category])
  @@map("inspection_templates")
}

model Inspection {
  id                String    @id @default(uuid()) @db.Uuid
  propertyId        String    @map("property_id") @db.Uuid
  templateId        String?   @map("template_id") @db.Uuid
  recurringTaskId   String?   @map("recurring_task_id") @db.Uuid
  title             String    @db.VarChar(200)
  category          String    @db.VarChar(50) // fire_safety, hvac, elevator, pool
  status            String    @default("scheduled") @db.VarChar(20) // scheduled, in_progress, completed, cancelled
  priority          String    @default("normal") @db.VarChar(20)
  scheduledDate     DateTime? @map("scheduled_date")
  startedAt         DateTime? @map("started_at")
  completedAt       DateTime? @map("completed_at")
  inspectorId       String?   @map("inspector_id") @db.Uuid
  location          String?   @db.VarChar(200)
  gpsLatitude       Float?    @map("gps_latitude")
  gpsLongitude      Float?    @map("gps_longitude")
  notes             String?   @db.VarChar(2000)
  createdById       String    @map("created_by_id") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  template InspectionTemplate? @relation(fields: [templateId], references: [id])
  items    InspectionItem[]

  @@index([propertyId])
  @@index([status])
  @@index([inspectorId])
  @@index([scheduledDate])
  @@map("inspections")
}

model InspectionItem {
  id           String    @id @default(uuid()) @db.Uuid
  inspectionId String    @map("inspection_id") @db.Uuid
  name         String    @db.VarChar(200)
  type         String    @db.VarChar(20) // pass_fail, numeric, text, photo
  required     Boolean   @default(true)
  sortOrder    Int       @default(0) @map("sort_order")
  value        String?   @db.VarChar(500) // pass, fail, numeric value, text
  numericValue Float?    @map("numeric_value")
  passed       Boolean?
  photoUrl     String?   @map("photo_url") @db.VarChar(500)
  notes        String?   @db.VarChar(1000)
  completedAt  DateTime? @map("completed_at")
  completedById String?  @map("completed_by_id") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([inspectionId])
  @@map("inspection_items")
}

// ---------------------------------------------------------------------------
// GOVERNANCE: Board Meetings, Voting, Financials, Resolutions
// ---------------------------------------------------------------------------

model BoardMeeting {
  id          String    @id @default(uuid()) @db.Uuid
  propertyId  String    @db.Uuid
  title       String    @db.VarChar(200)
  description String?   @db.Text
  scheduledAt DateTime  @map("scheduled_at")
  location    String?   @db.VarChar(200)
  status      String    @default("scheduled") @db.VarChar(20) // scheduled, in_progress, completed, cancelled
  type        String    @default("regular") @db.VarChar(20) // regular, special, agm, emergency
  createdBy   String    @map("created_by") @db.Uuid
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  agendaItems    AgendaItem[]
  votes          BoardVote[]
  minutes        MeetingMinutes[]
  resolutions    BoardResolution[]
  documents      GovernanceDocument[]
  property       Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@index([scheduledAt])
  @@map("board_meetings")
}

model AgendaItem {
  id           String  @id @default(uuid()) @db.Uuid
  meetingId    String  @map("meeting_id") @db.Uuid
  title        String  @db.VarChar(300)
  description  String? @db.Text
  sortOrder    Int     @default(0) @map("sort_order")
  requiresVote Boolean @default(false) @map("requires_vote")
  status       String  @default("pending") @db.VarChar(20) // pending, discussed, voted, deferred
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  meeting BoardMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  votes   BoardVote[]

  @@index([meetingId])
  @@map("agenda_items")
}

model BoardVote {
  id           String   @id @default(uuid()) @db.Uuid
  meetingId    String   @map("meeting_id") @db.Uuid
  agendaItemId String   @map("agenda_item_id") @db.Uuid
  propertyId   String   @db.Uuid
  voterId      String   @map("voter_id") @db.Uuid
  vote         String   @db.VarChar(10) // approve, reject, abstain
  createdAt    DateTime @default(now()) @map("created_at")

  meeting    BoardMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  agendaItem AgendaItem   @relation(fields: [agendaItemId], references: [id], onDelete: Cascade)

  @@unique([meetingId, agendaItemId, voterId])
  @@index([meetingId])
  @@index([agendaItemId])
  @@map("board_votes")
}

model MeetingMinutes {
  id         String   @id @default(uuid()) @db.Uuid
  meetingId  String   @map("meeting_id") @db.Uuid
  propertyId String   @db.Uuid
  content    String   @db.Text
  attendees  String[] // user IDs of attendees
  recordedBy String   @map("recorded_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  meeting BoardMeeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@index([meetingId])
  @@map("meeting_minutes")
}

model FinancialReport {
  id            String   @id @default(uuid()) @db.Uuid
  propertyId    String   @db.Uuid
  period        String   @db.VarChar(20) // e.g. "2026-Q1", "2026"
  totalRevenue  Int      @map("total_revenue")
  totalExpenses Int      @map("total_expenses")
  netIncome     Int      @map("net_income")
  categories    Json     @db.JsonB
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@index([period])
  @@map("financial_reports")
}

model BudgetLineItem {
  id              String @id @default(uuid()) @db.Uuid
  propertyId      String @db.Uuid
  category        String @db.VarChar(100)
  plannedAmount   Int    @map("planned_amount")
  actualAmount    Int    @map("actual_amount")
  period          String @db.VarChar(20) // e.g. "2026"
  variance        Int
  variancePercent Float  @map("variance_percent")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@index([period])
  @@map("budget_line_items")
}

model BoardResolution {
  id                     String    @id @default(uuid()) @db.Uuid
  propertyId             String    @db.Uuid
  title                  String    @db.VarChar(300)
  description            String?   @db.Text
  status                 String    @default("pending") @db.VarChar(20) // pending, approved, rejected, implemented
  meetingId              String?   @map("meeting_id") @db.Uuid
  approvedAt             DateTime? @map("approved_at")
  implementationDeadline DateTime? @map("implementation_deadline")
  createdBy              String    @map("created_by") @db.Uuid
  deletedAt              DateTime? @map("deleted_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  meeting  BoardMeeting? @relation(fields: [meetingId], references: [id])
  property Property      @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@index([meetingId])
  @@map("board_resolutions")
}

model GovernanceDocument {
  id          String   @id @default(uuid()) @db.Uuid
  propertyId  String   @db.Uuid
  title       String   @db.VarChar(300)
  type        String   @db.VarChar(30) // meeting_minutes, financial_statement, resolution, bylaw, policy, other
  filePath    String   @map("file_path") @db.VarChar(1000)
  description String?  @db.VarChar(2000)
  meetingId   String?  @map("meeting_id") @db.Uuid
  uploadedBy  String   @map("uploaded_by") @db.Uuid
  deletedAt   DateTime? @map("deleted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  meeting  BoardMeeting? @relation(fields: [meetingId], references: [id])
  property Property      @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@index([meetingId])
  @@map("governance_documents")
}

model BoardMemberRecord {
  id         String    @id @default(uuid()) @db.Uuid
  propertyId String    @db.Uuid
  userId     String    @db.Uuid
  name       String    @db.VarChar(200)
  email      String?   @db.VarChar(254)
  boardRole  String    @map("board_role") @db.VarChar(30) // president, vice_president, secretary, treasurer, director
  termStart  DateTime  @map("term_start")
  termEnd    DateTime  @map("term_end")
  status     String    @default("active") @db.VarChar(20) // active, expired, resigned
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

