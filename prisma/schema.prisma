model ResidentCard {
  id             String    @id @default(uuid()) @db.Uuid
  propertyId     String    @db.Uuid
  residentId     String    @db.Uuid
  unitId         String    @db.Uuid
  residentName   String    @db.VarChar(200)
  photoUrl       String?   @db.VarChar(500)
  accessLevel    String    @db.VarChar(30) // full, limited, temporary, restricted
  status         String    @default("active") @db.VarChar(20) // active, expired, revoked, lost
  qrCode         String    @unique @db.VarChar(100)
  designTemplate String    @default("standard") @map("design_template") @db.VarChar(100)
  expiresAt      DateTime  @map("expires_at")

  // Revocation / loss
  revokedAt      DateTime? @map("revoked_at")
  revokedReason  String?   @map("revoked_reason") @db.VarChar(500)
  replacesCardId String?   @map("replaces_card_id") @db.Uuid

  // Passport data (denormalized for quick lookup by security)
  moveInDate     DateTime? @map("move_in_date")

  // Audit
  issuedById     String?   @map("issued_by_id") @db.Uuid
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@index([residentId])
  @@index([unitId])
  @@index([status])
  @@index([qrCode])
  @@map("resident_cards")
}

