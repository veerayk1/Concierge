// ---------------------------------------------------------------------------
// ASSET MANAGEMENT: Physical asset tracking
// ---------------------------------------------------------------------------

model Asset {
  id              String    @id @default(uuid()) @db.Uuid
  propertyId      String    @db.Uuid
  tagNumber       String    @db.VarChar(50)
  description     String    @db.VarChar(500)
  category        String    @db.VarChar(30) // furniture, appliance, it, building_system
  status          String    @default("in_use") @db.VarChar(20) // in_use, in_storage, under_repair, disposed
  location        String    @db.VarChar(200)
  assignmentType  String?   @db.VarChar(20) // common_area, unit
  assignedToId    String?   @db.Uuid // unit ID if assigned to a unit
  purchaseDate    DateTime?
  purchaseValue   Float?
  usefulLifeYears Int?
  manufacturer    String?   @db.VarChar(200)
  modelNumber     String?   @db.VarChar(200)
  serialNumber    String?   @db.VarChar(200)
  notes           String?   @db.Text
  createdById     String?   @db.Uuid

