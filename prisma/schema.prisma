  @@index([propertyId])
  @@index([userId])
  @@map("board_member_records")
}

// ---------------------------------------------------------------------------
// FINANCIAL: Purchase Orders
// ---------------------------------------------------------------------------

model PurchaseOrder {
  id              String    @id @default(uuid()) @db.Uuid
  propertyId      String    @db.Uuid
  vendorId        String    @db.Uuid
  referenceNumber String    @unique @db.VarChar(20)
  status          String    @default("draft") @db.VarChar(20) // draft, submitted, approved, ordered, received, closed
  budgetCategory  String    @db.VarChar(100)
  priority        String    @default("normal") @db.VarChar(20) // low, normal, high, urgent
  totalAmount     Float     @default(0)
  expectedDelivery DateTime? @db.Date
  notes           String?   @db.VarChar(2000)

  // Invoice matching
  invoiceNumber   String?   @db.VarChar(100)
  invoiceDate     DateTime?
  invoiceAmount   Float?

  // Approval
  approvedById    String?   @db.Uuid
  approvedAt      DateTime?
  approvalNotes   String?   @db.VarChar(1000)

  // Audit
  createdById     String    @db.Uuid
  updatedById     String?   @db.Uuid
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  property    Property              @relation(fields: [propertyId], references: [id])
  vendor      Vendor                @relation(fields: [vendorId], references: [id])
  items       PurchaseOrderItem[]
  attachments PurchaseOrderAttachment[]

  @@index([propertyId])
  @@index([vendorId])
  @@index([status])
  @@index([referenceNumber])
  @@index([budgetCategory])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String @id @default(uuid()) @db.Uuid
  purchaseOrderId String @db.Uuid
  description     String @db.VarChar(500)
  quantity        Int
  unitPrice       Float
  total           Float

  createdAt DateTime @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

model PurchaseOrderAttachment {
  id              String @id @default(uuid()) @db.Uuid
  purchaseOrderId String @db.Uuid
  propertyId      String @db.Uuid
  fileName        String @db.VarChar(255)
  fileType        String @db.VarChar(100)
  fileSizeBytes   Int
  storageUrl      String @db.VarChar(500)
  uploadedById    String @db.Uuid

  createdAt DateTime @default(now())

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@map("purchase_order_attachments")
}

// ---------------------------------------------------------------------------
// RESIDENT CARDS & PASSPORTS
