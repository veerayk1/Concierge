// =============================================================================
// Concierge — Prisma Schema
// =============================================================================
// Multi-tenant by design: every user-visible table has property_id.
// UUID primary keys everywhere (prevents enumeration — SECURITY-RULEBOOK C.6.3).
// Soft deletes on all tables (deleted_at — SECURITY-RULEBOOK J.4).
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// CORE: Multi-Tenancy
// ---------------------------------------------------------------------------

model Property {
  id         String  @id @default(uuid()) @db.Uuid
  name       String  @db.VarChar(200)
  address    String  @db.VarChar(500)
  city       String  @db.VarChar(100)
  province   String  @db.VarChar(100)
  country    String  @default("CA") @db.VarChar(2)
  postalCode String  @db.VarChar(20)
  unitCount  Int     @default(0)
  timezone   String  @default("America/Toronto") @db.VarChar(50)
  logo       String? @db.VarChar(500)
  isActive   Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Business Operations fields
  type             PropertyType      @default(PRODUCTION)
  slug             String?           @unique
  branding         Json?             @db.JsonB
  subscriptionTier SubscriptionTier? @map("subscription_tier")
  expiresAt        DateTime?         @map("expires_at")
  parentPropertyId String?           @map("parent_property_id") @db.Uuid

  // Demo & Training fields (PRD 21)
  demoTemplateId         String?   @map("demo_template_id") @db.Uuid
  assignedSalesRepId     String?   @map("assigned_sales_rep_id") @db.Uuid
  demoLabel              String?   @map("demo_label") @db.VarChar(200)
  lastAccessedAt         DateTime? @map("last_accessed_at")
  prospectName           String?   @map("prospect_name") @db.VarChar(200)
  prospectLogoUrl        String?   @map("prospect_logo_url") @db.VarChar(500)
  prospectAccentColor    String?   @map("prospect_accent_color") @db.VarChar(20)
  notificationSuppressed Boolean   @default(false) @map("notification_suppressed")
  maxTrainees            Int?      @map("max_trainees")
  createdFromTemplate    String?   @map("created_from_template") @db.VarChar(100)

  // Property Code for login routing (PRD 22)
  propertyCode String? @unique @map("property_code") @db.VarChar(7) // e.g., "MPL-HTS"

  // Relations
  parentProperty   Property?          @relation("PropertyParent", fields: [parentPropertyId], references: [id])
  childProperties  Property[]         @relation("PropertyParent")
  demoTemplate     DemoTemplate?      @relation(fields: [demoTemplateId], references: [id])
  userProperties   UserProperty[]
  roles            Role[]
  eventGroups      EventGroup[]
  eventTypes       EventType[]
  events           Event[]
  buildings        Building[]
  units            Unit[]
  announcements    Announcement[]
  auditEntries     AuditEntry[]
  subscriptions    Subscription[]
  demoSessions     DemoSession[]
  trainingProgress TrainingProgress[]

  // Core module relations
  maintenanceRequests     MaintenanceRequest[]
  maintenanceCategories   MaintenanceCategory[]
  vendors                 Vendor[]
  vendorServiceCategories VendorServiceCategory[]
  equipment               Equipment[]
  amenities               Amenity[]
  amenityGroups           AmenityGroup[]
  bookings                Booking[]
  packages                Package[]
  courierTypes            CourierType[]
  storageSpots            StorageSpot[]
  parcelCategories        ParcelCategory[]

  // Security module relations
  visitorEntries  VisitorEntry[]
  incidentReports IncidentReport[]
  incidentTypes   IncidentType[]
  securityShifts  SecurityShift[]
  keyInventory    KeyInventory[]
  passOnLogs      PassOnLog[]
  staffBulletins  StaffBulletin[]

  // Parking module relations
  parkingAreas      ParkingArea[]
  parkingPermits    ParkingPermit[]
  parkingViolations ParkingViolation[]
  permitTypes       PermitType[]

  // Communication module relations
  announcementCategories AnnouncementCategory[]
  announcementTemplates  AnnouncementTemplate[]
  notificationTemplates  NotificationTemplate[]
  emergencyBroadcasts    EmergencyBroadcast[]

  // Training/LMS module relations
  courses       Course[]
  learningPaths LearningPath[]

  // Community module relations
  classifiedAds   ClassifiedAd[]
  ideas           Idea[]
  communityEvents CommunityEvent[]
  surveys         Survey[]
  libraryFolders  LibraryFolder[]
  forumTopics     ForumTopic[]
  photoAlbums            PhotoAlbum[]
  digitalSignageContents DigitalSignageContent[]

  // Dashboard & Reports module relations
  dashboardLayouts     DashboardLayout[]
  buildingHealthScores BuildingHealthScore[]
  aiBriefings          AIBriefing[]
  shiftHandoffs        ShiftHandoff[]
  reports              Report[]
  reportSchedules      ReportSchedule[]
  healthScores         HealthScore[]

  // Alteration module relations
  alterationProjects AlterationProject[]

  // Settings & Admin module relations
  propertySettings       PropertySettings?
  customFieldDefinitions CustomFieldDefinition[]
  residentGroups         ResidentGroup[]
  integrationConfigs     IntegrationConfig[]

  // Governance module relations
  boardMeetings       BoardMeeting[]
  financialReports    FinancialReport[]
  budgetLineItems     BudgetLineItem[]
  boardResolutions    BoardResolution[]
  governanceDocuments GovernanceDocument[]
  boardMemberRecords  BoardMemberRecord[]

  // Financial module relations
  purchaseOrders PurchaseOrder[]

  // Resident Cards & Passports module relations
  residentCards ResidentCard[]

  // Building Directory & Asset Management module relations
  directoryEntries          DirectoryEntry[]
  propertyEmergencyContacts PropertyEmergencyContact[]
  assets                    Asset[]
  assetAudits               AssetAudit[]

  // Know Your Residents module relations
  kyrSessions      KyrSession[]
  kyrLeaderboard   KyrLeaderboard[]

  // Parking limit configs
  parkingLimitConfigs ParkingLimitConfig[]

  // Email configuration
  eventTypeEmailConfigs EventTypeEmailConfig[]

  // Vacation tracking
  vacationPeriods VacationPeriod[]

  @@index([type])
  @@index([slug])
  @@index([propertyCode])
  @@index([parentPropertyId])
  @@map("properties")
}

// ---------------------------------------------------------------------------
// AUTH: Users, Roles, Sessions
// ---------------------------------------------------------------------------

model User {
  id           String    @id @default(uuid()) @db.Uuid
  email        String    @unique @db.VarChar(254)
  passwordHash String    @db.VarChar(255)
  firstName    String    @db.VarChar(100)
  lastName     String    @db.VarChar(100)
  phone        String?   @db.VarChar(20)
  avatarUrl    String?   @db.VarChar(500)
  salutation   String?   @db.VarChar(10) // Mr., Mrs., Ms., Dr., etc.
  languagePreference String @default("en") @db.VarChar(5) // en, fr-CA
  assistanceRequired Boolean @default(false) // Emergency mobility/medical needs flag
  mfaEnabled   Boolean   @default(false)
  mfaSecret    String?   @db.VarChar(500) // Encrypted at application layer
  isActive     Boolean   @default(true)
  activatedAt  DateTime?
  lastLoginAt  DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  userProperties       UserProperty[]
  sessions             Session[]
  refreshTokens        RefreshToken[]
  loginAudits          LoginAudit[]
  passwordHistory      PasswordHistory[]
  devicePushTokens     DevicePushToken[]
  occupancyRecords     OccupancyRecord[]
  kyrSessions          KyrSession[]
  kyrLeaderboardEntries KyrLeaderboard[]

  @@map("users")
}

/// Junction: one user can have different roles at different properties
model UserProperty {
  id         String @id @default(uuid()) @db.Uuid
  userId     String @db.Uuid
  propertyId String @db.Uuid
  roleId     String @db.Uuid

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user     User     @relation(fields: [userId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])
  role     Role     @relation(fields: [roleId], references: [id])

  @@unique([userId, propertyId])
  @@index([propertyId])
  @@map("user_properties")
}

model Role {
  id          String  @id @default(uuid()) @db.Uuid
  propertyId  String  @db.Uuid
  name        String  @db.VarChar(100)
  slug        String  @db.VarChar(100)
  description String? @db.VarChar(500)
  isSystem    Boolean @default(false) // Built-in roles cannot be deleted
  permissions Json    @default("[]") // Array of permission strings

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  property       Property       @relation(fields: [propertyId], references: [id])
  userProperties UserProperty[]

  @@unique([propertyId, slug])
  @@map("roles")
}

model Session {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @db.Uuid
  deviceFingerprint String   @db.VarChar(64)
  ipAddress         String   @db.VarChar(45)
  userAgent         String   @db.VarChar(500)
  lastActiveAt      DateTime @default(now())
  expiresAt         DateTime

  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("sessions")
}

model RefreshToken {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @db.Uuid
  tokenHash         String    @unique @db.VarChar(64) // SHA-256 hash
  deviceFingerprint String    @db.VarChar(64)
  ipAddress         String    @db.VarChar(45)
  expiresAt         DateTime
  rotatedAt         DateTime?
  revokedAt         DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordHistory {
  id           String @id @default(uuid()) @db.Uuid
  userId       String @db.Uuid
  passwordHash String @db.VarChar(255)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("password_history")
}

// ---------------------------------------------------------------------------
// AUDIT: Login & PII Access (INSERT-only tables)
// ---------------------------------------------------------------------------

model LoginAudit {
  id         String  @id @default(uuid()) @db.Uuid
  userId     String? @db.Uuid
  email      String  @db.VarChar(254)
  ipAddress  String  @db.VarChar(45)
  userAgent  String  @db.VarChar(500)
  geoCity    String? @db.VarChar(100)
  geoCountry String? @db.VarChar(2)
  success    Boolean
  failReason String? @db.VarChar(100)
  sessionId  String? @db.Uuid

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([email])
  @@index([ipAddress])
  @@map("login_audits")
}

model AuditEntry {
  id          String  @id @default(uuid()) @db.Uuid
  propertyId  String  @db.Uuid
  userId      String  @db.Uuid
  action      String  @db.VarChar(20) // read, create, update, delete
  resource    String  @db.VarChar(100) // table name
  resourceId  String  @db.Uuid
  fields      Json? // Which fields were accessed/modified
  ipAddress   String  @db.VarChar(45)
  userAgent   String? @db.VarChar(500)
  piiAccessed Boolean @default(false)

  createdAt DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId])
  @@index([userId])
  @@index([resource, resourceId])
  @@map("audit_entries")
}

// ---------------------------------------------------------------------------
// UNIFIED EVENT MODEL
// ---------------------------------------------------------------------------

model EventGroup {
  id          String  @id @default(uuid()) @db.Uuid
  propertyId  String  @db.Uuid
  name        String  @db.VarChar(100)
  slug        String  @db.VarChar(100)
  description String? @db.VarChar(500)
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  property   Property    @relation(fields: [propertyId], references: [id])
  eventTypes EventType[]

  @@unique([propertyId, slug])
  @@map("event_groups")
}

model EventType {
  id                 String  @id @default(uuid()) @db.Uuid
  propertyId         String  @db.Uuid
  eventGroupId       String  @db.Uuid
  name               String  @db.VarChar(100)
  slug               String  @db.VarChar(100)
  icon               String  @default("circle") @db.VarChar(50)
  color              String  @default("#2563EB") @db.VarChar(7)
  defaultPriority    String  @default("normal") @db.VarChar(20)
  notifyOnCreate     Boolean @default(true)
  notifyOnClose      Boolean @default(false)
  showOnLobby        Boolean @default(false)
  customFieldsSchema Json? // JSON Schema for custom fields
  isActive           Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  property    Property              @relation(fields: [propertyId], references: [id])
  eventGroup  EventGroup            @relation(fields: [eventGroupId], references: [id])
  events      Event[]
  emailConfig EventTypeEmailConfig?

  @@unique([propertyId, slug])
  @@map("event_types")
}

model Event {
  id           String    @id @default(uuid()) @db.Uuid
  propertyId   String    @db.Uuid
  eventTypeId  String    @db.Uuid
  unitId       String?   @db.Uuid
  status       String    @default("open") @db.VarChar(20)
  priority     String    @default("normal") @db.VarChar(20)
  title        String    @db.VarChar(200)
  description  String?   @db.Text
  customFields Json? // JSONB for configurable fields
  createdById  String    @db.Uuid
  closedById   String?   @db.Uuid
  closedAt     DateTime?
  referenceNo  String    @db.VarChar(20)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  property  Property  @relation(fields: [propertyId], references: [id])
  eventType EventType @relation(fields: [eventTypeId], references: [id])
  unit      Unit?     @relation(fields: [unitId], references: [id])

  @@index([propertyId, status])
  @@index([propertyId, eventTypeId])
  @@index([propertyId, createdAt])
  @@index([unitId])
  @@map("events")
}

// ---------------------------------------------------------------------------
// BUILDING: Buildings & Units
// ---------------------------------------------------------------------------

model Building {
  id          String  @id @default(uuid()) @db.Uuid
  propertyId  String  @db.Uuid
  name        String  @db.VarChar(100)
  address     String? @db.VarChar(500)
  totalFloors Int     @default(1)
  totalUnits  Int     @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  property     Property      @relation(fields: [propertyId], references: [id])
  units        Unit[]
  parkingAreas ParkingArea[]

  @@unique([propertyId, name])
  @@index([propertyId])
  @@map("buildings")
}

model Unit {
  id                       String   @id @default(uuid()) @db.Uuid
  propertyId               String   @db.Uuid
  buildingId               String?  @db.Uuid
  number                   String   @db.VarChar(20)
  floor                    Int?
  unitType                 String   @default("residential") @db.VarChar(50) // residential, commercial, storage, parking
  status                   String   @default("vacant") @db.VarChar(20) // occupied, vacant, under_renovation
  squareFootage            Decimal? @db.Decimal(10, 2)
  enterPhoneCode           String?  @db.VarChar(20)
  parkingSpot              String?  @db.VarChar(20)
  locker                   String?  @db.VarChar(20)
  keyTag                   String?  @db.VarChar(50)
  packageEmailNotification Boolean  @default(true)
  comments                 String?  @db.Text
  customFields             Json?    @db.JsonB

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  property            Property             @relation(fields: [propertyId], references: [id])
  building            Building?            @relation(fields: [buildingId], references: [id])
  events              Event[]
  unitInstructions    UnitInstruction[]
  occupancyRecords    OccupancyRecord[]
  fobs                Fob[]
  buzzerCodes         BuzzerCode[]
  garageClickers      GarageClicker[]
  pets                Pet[]
  vehicles            Vehicle[]
  emergencyContacts   EmergencyContact[]
  maintenanceRequests MaintenanceRequest[]
  bookings            Booking[]
  packages            Package[]
  parkingPermits      ParkingPermit[]
  parkingSpots        ParkingSpot[]        @relation("AssignedUnit")
  visitorEntries      VisitorEntry[]
  authorizedDelegates AuthorizedDelegate[]
  alterationProjects  AlterationProject[]

  @@unique([propertyId, number])
  @@index([propertyId])
  @@index([buildingId])
  @@index([propertyId, status])
  @@map("units")
}

model UnitInstruction {
  id              String   @id @default(uuid()) @db.Uuid
  unitId          String   @db.Uuid
  propertyId      String   @db.Uuid
  instructionText String   @db.VarChar(1000)
  priority        String   @default("normal") @db.VarChar(20) // normal, important, critical
  visibleToRoles  String[] // Role IDs
  isActive        Boolean  @default(true)
  createdById     String   @db.Uuid
  updatedById     String?  @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit Unit @relation(fields: [unitId], references: [id])

  @@index([unitId])
  @@index([propertyId])
  @@map("unit_instructions")
}

model OccupancyRecord {
  id           String    @id @default(uuid()) @db.Uuid
  unitId       String    @db.Uuid
  userId       String    @db.Uuid
  propertyId   String    @db.Uuid
  residentType String    @db.VarChar(50) // owner, tenant, offsite_owner, family_member
  moveInDate   DateTime  @db.Date
  moveOutDate  DateTime? @db.Date
  isPrimary    Boolean   @default(false)
  notes        String?   @db.VarChar(500)
  recordedById String    @db.Uuid

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  unit Unit @relation(fields: [unitId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([unitId])
  @@index([userId])
  @@index([propertyId, moveOutDate])
  @@map("occupancy_records")
}

// ---------------------------------------------------------------------------
// COMMUNICATION: Announcements
// ---------------------------------------------------------------------------

model Announcement {
  id                    String    @id @default(uuid()) @db.Uuid
  propertyId            String    @db.Uuid
  title                 String    @db.VarChar(200)
  content               String    @db.Text
  contentPlaintext      String?   @db.Text // auto-generated stripped HTML
  categoryId            String?   @db.Uuid
  tags                  String[]
  priority              String    @default("normal") @db.VarChar(20) // low, normal, high, urgent
  status                String    @default("draft") @db.VarChar(20) // draft, scheduled, published, expired, rejected
  audience              Json?     @db.JsonB // targeting criteria
  channels              Json      @default("[\"web\"]") // ["web", "email", "sms", "push", "voice", "lobby_display"]
  isPinned              Boolean   @default(false)
  pinnedAt              DateTime?
  pinnedById            String?   @db.Uuid
  isEmergency           Boolean   @default(false)
  requireAcknowledgment Boolean   @default(false)
  publishedAt           DateTime?
  scheduledAt           DateTime?
  expiresAt             DateTime?
  createdById           String    @db.Uuid
  approvedById          String?   @db.Uuid
  approvedAt            DateTime?
  rejectedById          String?   @db.Uuid
  rejectedAt            DateTime?
  rejectionReason       String?   @db.VarChar(500)
  aiMetadata            Json?     @db.JsonB
  engagementSummary     Json?     @db.JsonB

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  property   Property               @relation(fields: [propertyId], references: [id])
  category   AnnouncementCategory?  @relation("CategoryAnnouncements", fields: [categoryId], references: [id])
  deliveries AnnouncementDelivery[]

  @@index([propertyId, publishedAt])
  @@index([propertyId, status])
  @@map("announcements")
}

// ---------------------------------------------------------------------------
// SECURITY CONSOLE: Visitor, Package, Incident, Shift, Key Management
// ---------------------------------------------------------------------------

model VisitorEntry {
  id                  String    @id @default(uuid()) @db.Uuid
  eventId             String?   @unique @db.Uuid
  propertyId          String    @db.Uuid
  unitId              String    @db.Uuid
  visitorName         String    @db.VarChar(100)
  visitorType         String    @default("visitor") @db.VarChar(30) // visitor, contractor, delivery_person, real_estate_agent, emergency_service, other
  arrivalAt           DateTime  @default(now())
  departureAt         DateTime?
  expectedDepartureAt DateTime?
  signedOutById       String?   @db.Uuid
  notifyResident      Boolean   @default(true)
  photoUrl            String?   @db.VarChar(500)
  comments            String?   @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property             Property              @relation(fields: [propertyId], references: [id])
  unit                 Unit                  @relation(fields: [unitId], references: [id])
  visitorParkingPermit VisitorParkingPermit?

  @@index([propertyId, arrivalAt])
  @@index([unitId])
  @@map("visitor_entries")
}

model VisitorParkingPermit {
  id               String   @id @default(uuid()) @db.Uuid
  visitorEntryId   String   @unique @db.Uuid
  propertyId       String   @db.Uuid
  vehicleMakeModel String   @db.VarChar(100)
  licensePlate     String   @db.VarChar(20)
  provinceState    String   @db.VarChar(50)
  vehicleColor     String?  @db.VarChar(30)
  parkingArea      String?  @db.VarChar(100)
  permitStart      DateTime
  permitEnd        DateTime
  status           String   @default("active") @db.VarChar(20) // active, expired, cancelled
  printed          Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visitorEntry VisitorEntry @relation(fields: [visitorEntryId], references: [id])

  @@index([licensePlate])
  @@index([propertyId, status, permitEnd])
  @@map("visitor_parking_permits")
}

model CourierType {
  id         String  @id @default(uuid()) @db.Uuid
  propertyId String? @db.Uuid // null = system default
  name       String  @db.VarChar(50)
  slug       String  @db.VarChar(50)
  iconUrl    String  @db.VarChar(500)
  color      String? @db.VarChar(7)
  sortOrder  Int     @default(0)
  isActive   Boolean @default(true)
  isSystem   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  property Property? @relation(fields: [propertyId], references: [id])
  packages Package[]

  @@map("courier_types")
}

model Package {
  id                   String    @id @default(uuid()) @db.Uuid
  propertyId           String    @db.Uuid
  unitId               String    @db.Uuid
  residentId           String?   @db.Uuid
  referenceNumber      String    @db.VarChar(20)
  direction            String    @default("incoming") @db.VarChar(10) // incoming, outgoing
  status               String    @default("unreleased") @db.VarChar(20) // unreleased, released, returned, disposed
  courierId            String?   @db.Uuid
  courierOtherName     String?   @db.VarChar(100)
  trackingNumber       String?   @db.VarChar(100)
  parcelCategoryId     String?   @db.Uuid
  description          String?   @db.VarChar(500)
  storageSpotId        String?   @db.Uuid
  isPerishable         Boolean   @default(false)
  isOversized          Boolean   @default(false)
  notifyChannel        String    @default("default") @db.VarChar(10) // default, email, sms, push, voice, all, none
  createdById          String    @db.Uuid
  releasedToName       String?   @db.VarChar(200)
  releasedById         String?   @db.Uuid
  releasedAt           DateTime?
  idVerified           Boolean   @default(false)
  releaseComments      String?   @db.VarChar(500)
  isAuthorizedDelegate Boolean   @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  property       Property           @relation(fields: [propertyId], references: [id])
  unit           Unit               @relation(fields: [unitId], references: [id])
  courier        CourierType?       @relation(fields: [courierId], references: [id])
  parcelCategory ParcelCategory?    @relation(fields: [parcelCategoryId], references: [id])
  storageSpot    StorageSpot?       @relation(fields: [storageSpotId], references: [id])
  photos         PackagePhoto[]
  signatures     PackageSignature[]
  history        PackageHistory[]

  @@index([propertyId, status])
  @@index([unitId, status])
  @@index([propertyId, referenceNumber])
  @@index([trackingNumber])
  @@index([propertyId, createdAt])
  @@index([propertyId, releasedAt])
  @@index([propertyId, isPerishable, status])
  @@map("packages")
}

model PackagePhoto {
  id            String   @id @default(uuid()) @db.Uuid
  packageId     String   @db.Uuid
  photoType     String   @db.VarChar(20) // intake, release, damage
  fileUrl       String   @db.VarChar(500)
  fileSizeBytes Int
  uploadedById  String   @db.Uuid
  uploadedAt    DateTime @default(now())

  package Package @relation(fields: [packageId], references: [id])

  @@index([packageId])
  @@map("package_photos")
}

model PackageSignature {
  id            String   @id @default(uuid()) @db.Uuid
  packageId     String   @db.Uuid
  signatureData Bytes
  signedByName  String   @db.VarChar(200)
  capturedAt    DateTime @default(now())
  capturedById  String   @db.Uuid

  package Package @relation(fields: [packageId], references: [id])

  @@index([packageId])
  @@map("package_signatures")
}

model PackageHistory {
